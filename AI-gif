<!DOCTYPE html>
<html>
<head>
<style>
body {
  margin: 0;
  height: 100vh;
  background: linear-gradient(to right, #1e3c72, #2a5298);
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: Arial;
}

.text {
  color: white;
  font-size: 50px;
  font-weight: bold;
  animation: float 2s infinite alternate;
  text-shadow: 0 0 20px #00f0ff;
}

@keyframes float {
  from {
    transform: translateY(0px);
    opacity: 0.6;
  }
  to {
    transform: translateY(-20px);
    opacity: 1;
  }
}
</style>
</head>

<body>

<div class="text">☁️ Welcome to Cloud Platform ☁️</div>

</body>
</html>
