<!DOCTYPE html>
<html>
<head>
<style>
body {
  background: black;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* AI glowing animation */
.ai-box {
  font-size: 60px;
  font-weight: bold;
  color: #00ffcc;
  text-shadow: 0 0 10px #00ffcc, 0 0 20px #00ffcc;
  animation: glow 1s infinite alternate;
}

@keyframes glow {
  from {
    transform: scale(1);
    opacity: 0.6;
  }
  to {
    transform: scale(1.2);
    opacity: 1;
  }
}
</style>
</head>

<body>

<div class="ai-box">🤖 AI IMAGE</div>

</body>
</html>
